{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo \"No install needed for static report\"",
  "buildCommand": "echo \"Using prebuilt Cashlog model report\"",
  "outputDirectory": "reports/cashlog_model_report",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/report",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
