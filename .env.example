# Fail-closed production model worker. Generate a unique 48+ byte secret.
CATAI_REQUIRE_INTERNAL_API_KEY=true
CATAI_INTERNAL_API_KEY=replace-with-a-secret-manager-value

# Keep the worker local or bind specifically to a Tailscale interface.
CASHLOG_API_HOST=127.0.0.1
CASHLOG_API_PORT=8010

# Browser origins only. Native React Native requests are routed through NestJS.
CATAI_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
